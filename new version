local function C_177()
local script = G2L["177"];
	-- SERVICES
	local UIS = game:GetService("UserInputService")
	local RS = game:GetService("RunService")
	local Players = game:GetService("Players")
	
	-- PLAYER / CAMERA
	local lp = Players.LocalPlayer
	local cam = workspace.CurrentCamera
	local mouse = lp:GetMouse()
	
	-- UI (Slider references removed)
	local menu = script.Parent.Parent
	local aimBtn   = menu:WaitForChild("ambo")
	local teamBtn  = menu:WaitForChild("tmchk")
	local wallBtn  = menu:WaitForChild("wchk")
	
	-- STATES
	local aim_On = false
	local aim_TC = true
	local aim_WC = true
	local aiming = false
	
	-- SETTINGS
	local FOV_RADIUS = 150
	local TARGET_PART = "Head"
	
	-- INTERNAL (Stickiness locked to 100%)
	local stickiness = 1 
	local lockedTarget = nil
	
	---------------------------------------------------
	-- BUTTONS
	---------------------------------------------------
	aimBtn.MouseButton1Click:Connect(function()
		aim_On = not aim_On
		aimBtn.Text = "Aimbot-" .. (aim_On and "ON" or "OFF")
	end)
	
	teamBtn.MouseButton1Click:Connect(function()
		aim_TC = not aim_TC
		teamBtn.Text = "TeamCheck-" .. (aim_TC and "ON" or "OFF")
	end)
	
	wallBtn.MouseButton1Click:Connect(function()
		aim_WC = not aim_WC
		wallBtn.Text = "WallCheck-" .. (aim_WC and "ON" or "OFF")
	end)
	
	-----------------------------------
	-- INPUT
	-----------------------------------
	UIS.InputBegan:Connect(function(input, gpe)
		if gpe then return end
		if input.UserInputType == Enum.UserInputType.MouseButton2 then
			aiming = true
			lockedTarget = nil
		end
	end)
	
	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton2 then
			aiming = false
			lockedTarget = nil
		end
	end)
	
	-----------------------------------
	-- CHECKS (ForceField & Wall)
	-----------------------------------
	local function hasForceField(char)
		return char and char:FindFirstChildOfClass("ForceField") ~= nil
	end
	
	local function wallCheck(char, part)
		if not aim_WC then return true end
		local origin = cam.CFrame.Position
		local direction = part.Position - origin
		local params = RaycastParams.new()
		params.FilterType = Enum.RaycastFilterType.Exclude
		params.FilterDescendantsInstances = { lp.Character, cam }
		local result = workspace:Raycast(origin, direction, params)
		if not result then return true end
		return result.Instance:IsDescendantOf(char)
	end
	
	-----------------------------------
	-- GET TARGET
	-----------------------------------
	local function getTarget()
		local closestDist = FOV_RADIUS
		local closestPart = nil
	
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= lp then
				if aim_TC and player.Team == lp.Team then continue end
				local char = player.Character
				if not char or hasForceField(char) then continue end
				local humanoid = char:FindFirstChildOfClass("Humanoid")
				local part = char:FindFirstChild(TARGET_PART)
				if not humanoid or humanoid.Health <= 0 or not part then continue end
	
				local screenPos, onScreen = cam:WorldToViewportPoint(part.Position)
				if not onScreen then continue end
	
				local dist = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
				if dist < closestDist and wallCheck(char, part) then
					closestDist = dist
					closestPart = part
				end
			end
		end
		return closestPart
	end
	
	-----------------------------------
	-- AIMBOT LOOP
	-----------------------------------
	RS.RenderStepped:Connect(function()
		if not aim_On or not aiming then 
			lockedTarget = nil
			return 
		end
	
		-- 1. OVĚŘENÍ AKTUÁLNÍHO CÍLE (Pokud nějaký máme)
		if lockedTarget then
			local char = lockedTarget.Parent
			local humanoid = char and char:FindFirstChildOfClass("Humanoid")
	
			-- Kontrola: Je naživu? Má ForceField? Je za zdí?
			local isInvalid = not char 
				or not humanoid 
				or humanoid.Health <= 0 
				or hasForceField(char) 
				or not wallCheck(char, lockedTarget)
	
			if isInvalid then
				lockedTarget = nil -- Zruš zámek, pokud cíl nesplňuje podmínky
			end
		end
	
		-- 2. HLEDÁNÍ NOVÉHO CÍLE (Pokud nemáme zámek)
		if not lockedTarget then
			lockedTarget = getTarget()
		end
	
		-- 3. SAMOTNÉ MÍŘENÍ
		if lockedTarget then
			local targetPos = lockedTarget.Position
	
			-- Otočení kamery
			cam.CFrame = CFrame.new(cam.CFrame.Position, targetPos)
	
			-- Otočení postavy (pouze horizontálně)
			if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
				local hrp = lp.Character.HumanoidRootPart
				local lookAt = Vector3.new(targetPos.X, hrp.Position.Y, targetPos.Z)
				hrp.CFrame = CFrame.new(hrp.Position, lookAt)
			end
		end
	end)
end;
