local function C_6d()
local script = G2L["6d"];
	local UIS = game:GetService("UserInputService")
	local RunService = game:GetService("RunService")
	local player = game.Players.LocalPlayer
	local camera = workspace.CurrentCamera
	
	local button = script.Parent
	local speedInput = button.Parent:WaitForChild("FlSped")
	
	local flying = false
	local flyActive = false
	local bodyVelocity = nil
	local animConnection = nil
	
	-- Kills all walking/jumping animations
	local function setAnims(state)
		local char = player.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		if not hum then return end
		if state == false then
			for _, v in pairs(hum:GetPlayingAnimationTracks()) do v:Stop() end
			animConnection = hum.AnimationPlayed:Connect(function(track) track:Stop() end)
		elseif animConnection then
			animConnection:Disconnect()
			animConnection = nil
		end
	end
	
	local function toggleFlyMode(state)
		flyActive = state
		local char = player.Character
		local hum = char and char:FindFirstChildOfClass("Humanoid")
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if not hum or not root then return end
	
		if flyActive then
			local seat = hum.SeatPart
	
			-- 1. LOCKDOWN: Physically weld and disable seat ejection
			if seat then
				seat.Disabled = true
				local lock = root:FindFirstChild("FlySeatLock") or Instance.new("WeldConstraint")
				lock.Name = "FlySeatLock"
				lock.Part0 = root
				lock.Part1 = seat
				lock.Parent = root
			end
	
			-- 2. SETUP FLY PHYSICS
			setAnims(false)
			hum.PlatformStand = true
			-- We use "Heuristic" state to stay under the anti-cheat radar
			hum:ChangeState(Enum.HumanoidStateType.None) 
	
			bodyVelocity = root:FindFirstChild("FlyVelocity") or Instance.new("BodyVelocity")
			bodyVelocity.Name = "FlyVelocity"
			bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
			bodyVelocity.Velocity = Vector3.new(0, 0, 0)
			bodyVelocity.Parent = root
	
			RunService:BindToRenderStep("FlyLoop", Enum.RenderPriority.Camera.Value, function()
				if UIS:GetFocusedTextBox() then bodyVelocity.Velocity = Vector3.new(0,0,0) return end
	
				-- Force the 'Sitting' state and animation every single frame
				if seat then 
					hum.Sit = true 
				end
	
				local currentSpeed = tonumber(speedInput.Text) or 16
				local direction = Vector3.new(0, 0, 0)
	
				-- Control Logic
				if UIS:IsKeyDown(Enum.KeyCode.W) then direction = direction + camera.CFrame.LookVector end
				if UIS:IsKeyDown(Enum.KeyCode.S) then direction = direction - camera.CFrame.LookVector end
				if UIS:IsKeyDown(Enum.KeyCode.A) then direction = direction - camera.CFrame.RightVector end
				if UIS:IsKeyDown(Enum.KeyCode.D) then direction = direction + camera.CFrame.RightVector end
				if UIS:IsKeyDown(Enum.KeyCode.Space) then direction = direction + Vector3.new(0, 1, 0) end
				if UIS:IsKeyDown(Enum.KeyCode.Q) then direction = direction - Vector3.new(0, 1, 0) end
	
				root.RotVelocity = Vector3.new(0, 0, 0)
				bodyVelocity.Velocity = direction.Magnitude > 0 and direction.Unit * currentSpeed or Vector3.new(0,0,0)
	
				-- Update CFrame so the character and seat rotate with the camera
				root.CFrame = CFrame.new(root.Position, root.Position + camera.CFrame.LookVector)
			end)
		else
			-- 3. CLEAN RESET
			RunService:UnbindFromRenderStep("FlyLoop")
			if bodyVelocity then bodyVelocity:Destroy() end
	
			setAnims(true)
			hum.PlatformStand = false
			hum:ChangeState(Enum.HumanoidStateType.GettingUp)
	
			-- Unlock the world
			for _, v in pairs(workspace:GetDescendants()) do
				if v:IsA("Seat") or v:IsA("VehicleSeat") then v.Disabled = false end
			end
		end
	end
	
	-- 4. THE ANTI-EJECT CLEANUP
	local function setup(h)
		h:GetPropertyChangedSignal("Sit"):Connect(function()
			-- If the game tries to eject us while flying is ON, we force ourselves back
			if not h.Sit and flyActive then
				h.Sit = true
			elseif not h.Sit and not flyActive then
				-- Normal exit when flying is off
				local r = h.Parent:FindFirstChild("HumanoidRootPart")
				if r and r:FindFirstChild("FlySeatLock") then r.FlySeatLock:Destroy() end
				for _, v in pairs(workspace:GetDescendants()) do
					if v:IsA("Seat") or v:IsA("VehicleSeat") then v.Disabled = false end
				end
			end
		end)
	end
	
	player.CharacterAdded:Connect(function(c) setup(c:WaitForChild("Humanoid")) end)
	if player.Character then setup(player.Character:WaitForChild("Humanoid")) end
	
	button.MouseButton1Click:Connect(function()
		flying = not flying
		button.Text = flying and "Flying-ON" or "Flying-OFF"
		toggleFlyMode(flying)
	end)
	
	UIS.InputBegan:Connect(function(i, g)
		if not g and i.KeyCode == Enum.KeyCode.LeftAlt and flying then
			flyActive = not flyActive
			toggleFlyMode(flyActive)
		end
	end)
end;
