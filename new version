	local function setupModal()
		local modalFix = mainFrame:FindFirstChild("ModalFix")
		if not modalFix then
			modalFix = Instance.new("TextButton")
			modalFix.Name = "ModalFix"
			modalFix.Size = UDim2.new(0, 0, 0, 0)
			modalFix.BackgroundTransparency = 1
			modalFix.Text = ""
			modalFix.Parent = mainFrame
		end
		return modalFix
	end
	
	local modalButton = setupModal()
	
	local function updateToggleButtonUI()
		lobut.Text = lockEnabled and "Mouse Lock: ON" or "Mouse Lock: OFF"
	end
	
	local function updateMouseBehavior()
		-- Pokud je LOCK zapnutý, skript NIC nedělá (myš zůstane ve hře zamknutá)
		if lockEnabled then
			modalButton.Modal = false
			return 
		end
	
		-- Pokud je LOCK vypnutý (OFF), skript ovládá myš pro menu
		if menuOpen then
			modalButton.Modal = true
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		else
			modalButton.Modal = false
			-- Kontrola 1. osoby pro zamknutí při zavření
			if player.Character and player.Character:FindFirstChild("Head") then
				local distance = (player.Character.Head.Position - camera.CFrame.Position).Magnitude
				if distance < 1.5 then
					UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
				end
			end
		end
	end
	
	-- Logika tlačítka lobut
	lobut.MouseButton1Click:Connect(function()
		lockEnabled = not lockEnabled
		updateToggleButtonUI()
		updateMouseBehavior()
	end)
	
	-- Klávesa J
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if not gameProcessed and input.KeyCode == Enum.KeyCode.J then
			menuOpen = not menuOpen
			mainFrame.Visible = menuOpen
			updateMouseBehavior()
		end
	end)
	
	-- Pojistka v RenderStepped běží jen pokud je mechanismus uvolňování aktivní
	RunService.RenderStepped:Connect(function()
		if menuOpen and not lockEnabled then
			UserInputService.MouseBehavior = Enum.MouseBehavior.Default
		end
	end)
	
	-- Inicializace
	updateToggleButtonUI()
	updateMouseBehavior()
	
end;
