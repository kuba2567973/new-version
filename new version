local function C_18a()
local script = G2L["18a"];
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local LocalPlayer = Players.LocalPlayer
	
	local auraButton = script.Parent.Parent:WaitForChild("ka")
	local teamButton = script.Parent.Parent:WaitForChild("tmchka")
	
	local auraEnabled = false
	local teamCheckEnabled = true
	local killDelay = 0.1 -- V Trench War doporučuji mírně pomalejší interval kvůli anticheatu
	
	-- 1. FILTRACE CÍLŮ
	local function canAttack(player)
		if not player or player == LocalPlayer or not player.Character then return false end
		local char = player.Character
		local hum = char:FindFirstChild("Humanoid")
	
		if not hum or hum.Health <= 0 or char:FindFirstChildOfClass("ForceField") then return false end
	
		-- Ignoruje specifické týmy
		local teamName = player.Team and player.Team.Name or ""
		if teamName == "Prisoners" or teamName == "Inmates" then return false end
	
		if teamCheckEnabled then
			local sameTeam = (player.Team == LocalPlayer.Team) or (player.TeamColor == LocalPlayer.TeamColor)
			if sameTeam then return false end
		end
	
		return true
	end
	
	-- 2. FUNKCE PRO ÚTOK (VYLEPŠENO PRO TRENCH WAR)
	local function forceAttack(targetChar)
		local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
		if not tool then return end
	
		tool:Activate()
	
		-- Hledání RemoteEventu pro poškození (Trench War/ACS/Carbon fix)
		-- Hry často používají eventy jako "Hit", "Fire", "Damage" nebo "Remote"
		local event = tool:FindFirstChild("Hit") or tool:FindFirstChild("Damage") or tool:FindFirstChild("Fire") or tool:FindFirstChildOfClass("RemoteEvent")
	
		if event and event:IsA("RemoteEvent") then
			-- Simulace zásahu do hlavy (Headshot)
			local head = targetChar:FindFirstChild("Head")
			if head then
				-- Posíláme serveru informaci o zásahu (argumenty se liší podle hry)
				event:FireServer(head, head.Position, targetChar)
			end
		end
	end
	
	-- 3. HLAVNÍ SMYČKA
	task.spawn(function()
		while true do
			task.wait(killDelay)
			if auraEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
				local myHRP = LocalPlayer.Character.HumanoidRootPart
	
				for _, player in pairs(Players:GetPlayers()) do
					if canAttack(player) then
						local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
						if targetHRP then
							-- Teleportace těsně za záda
							myHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 2.5)
	
							-- Útok
							forceAttack(player.Character)
	
							task.wait(0.12) -- Nutné pro registraci v Trench War
							break 
						end
					end
				end
			end
		end
	end)
	
	-- 4. TLAČÍTKA
	auraButton.MouseButton1Click:Connect(function()
		auraEnabled = not auraEnabled
		auraButton.Text = auraEnabled and "MassiveKillAura-ON" or "MassiveKillAura-OFF"
	end)
	
	teamButton.MouseButton1Click:Connect(function()
		teamCheckEnabled = not teamCheckEnabled
		teamButton.Text = teamCheckEnabled and "TeamCheck-ON" or "TeamCheck-OFF"
	end)
end;
