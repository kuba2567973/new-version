local function C_16()
local script = G2L["16"];
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local UserInputService = game:GetService("UserInputService")
	
	local LocalPlayer = Players.LocalPlayer
	local Camera = workspace.CurrentCamera
	local Gui = script.Parent -- Předpokládá se, že skript je v ScreenGui
	
	-- FLEXIBILNÍ VYHLEDÁVÁNÍ (Najde tlačítka kdekoli v Gui podle jména)
	local function find(name)
		return Gui:FindFirstChild(name, true)
	end
	
	local mainButton = find("ambo")
	local teamButton = find("tmchk")
	local espButton = find("es")
	local espTeamButton = find("tmchkwh")
	local esOutBox = find("EsOut")
	local esColBox = find("EsCol")
	
	-- KONTROLA, ZDA SE VŠE NAŠLO
	if not (mainButton and teamButton and espButton and espTeamButton and esOutBox and esColBox) then
		warn("!!! AIMBOT ERROR: Některá tlačítka nebyla nalezena. Zkontrolujte jména v Exploreru!")
		return
	end
	
	local aimEnabled, aimTeamCheck = false, true
	local espEnabled, espTeamCheck = false, true
	local isRightClick = false
	
	-- 1. TEAM CHECK LOGIKA (RIVALS FIX)
	local function isEnemy(player)
		if not player or player == LocalPlayer then return false end
	
		-- Pokud je TeamCheck vypnutý (v módu FFA), považujeme za nepřítele kohokoliv jiného
		local checkActive = (aimEnabled and aimTeamCheck) or (espEnabled and espTeamCheck)
		if not checkActive then return true end
	
		-- Klasické týmy a TeamColor
		if player.Team ~= LocalPlayer.Team then return true end
		if player.TeamColor ~= LocalPlayer.TeamColor then return true end
	
		-- Atributy (Rivals)
		if player:GetAttribute("Team") ~= LocalPlayer:GetAttribute("Team") then return true end
	
		return false
	end
	
	-- 2. POMOCNÉ FUNKCE
	local function getRGB(txt, default)
		local r, g, b = txt:match("(%d+),%s*(%d+),%s*(%d+)")
		return r and Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b)) or default
	end
	
	local function isVisible(part)
		local rayParams = RaycastParams.new()
		rayParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
		rayParams.FilterType = Enum.RaycastFilterType.Exclude
		local res = workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, rayParams)
		return res and res.Instance:IsDescendantOf(part.Parent) or false
	end
	
	-- 3. LOGIKA TLAČÍTEK
	mainButton.MouseButton1Click:Connect(function()
		aimEnabled = not aimEnabled
