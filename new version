local function C_21b()
local script = G2L["21b"];
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local LocalPlayer = Players.LocalPlayer
	
	local fldr = script.Parent.txbas.Pl
	
	local speedBox = fldr:WaitForChild("Speeed")
	local b1 = fldr:WaitForChild("unfast")
	local b2 = fldr:WaitForChild("fast")
	local b3 = fldr:WaitForChild("megafast")
	local b4 = fldr:WaitForChild("midfast")
	
	local targetSpeed = 16
	
	-- 1. FUNKCE PRO NASTAVENÍ RYCHLOSTI
	local function setSpeed(newSpeed)
		local val = tonumber(newSpeed)
		if val then
			targetSpeed = val
			speedBox.Text = tostring(val)
		end
	end
	
	-- 2. PŘIPOJENÍ TLAČÍTEK (Každé nastaví hodnotu podle svého textu)
	b1.MouseButton1Click:Connect(function() setSpeed(16) end)
	b2.MouseButton1Click:Connect(function() setSpeed(b2.Text) end)
	b3.MouseButton1Click:Connect(function() setSpeed(b3.Text) end)
	b4.MouseButton1Click:Connect(function() setSpeed(b4.Text) end)
	
	-- 3. LOGIKA TEXTBOXU
	speedBox.Focused:Connect(function()
		speedBox.Text = ""
	end)
	
	speedBox.FocusLost:Connect(function()
		setSpeed(speedBox.Text)
		if speedBox.Text == "" then speedBox.Text = tostring(targetSpeed) end
	end)
	
	-- 4. VYNUCENÍ RYCHLOSTI (Anti-Cheat & Crash protection)
	RunService.RenderStepped:Connect(function()
		local char = LocalPlayer.Character
		if not char then return end
	
		local humanoid = char:FindFirstChildOfClass("Humanoid")
		if humanoid then
			if humanoid.WalkSpeed ~= targetSpeed then
				pcall(function()
					humanoid.WalkSpeed = targetSpeed
				end)
			end
		end
	end)
	
end;
