local function C_20e()
local script = G2L["20e"];
	local player = game:GetService("Players").LocalPlayer
	local background = script.Parent -- This is "hltbar"
	local fillFrame = background:WaitForChild("bar") -- The moving green part
	local hpText = background:WaitForChild("hpnum") -- The "HP: XXX" text
	
	-- Your specific "Full" scale dimensions
	local MAX_SCALE_X = 1
	local MAX_SCALE_Y = 1
	
	local function updateUI(humanoid)
		local health = math.floor(humanoid.Health)
		local maxHealth = math.floor(humanoid.MaxHealth)
	
		-- Calculate the percentage (0 to 1)
		local healthRatio = math.clamp(health / maxHealth, 0, 1)
	
		-- 1. Update the Text
		hpText.Text = "HP: " .. health
	
		-- 2. Update the Bar using Scale
		-- We multiply the percentage by your specific max width (0.979)
		fillFrame:TweenSize(
			UDim2.new(healthRatio * MAX_SCALE_X, 0, MAX_SCALE_Y, 0),
			Enum.EasingDirection.Out,
			Enum.EasingStyle.Quad,
			0.3,
			true
		)
	end
	
	local function setupCharacter(char)
		local humanoid = char:WaitForChild("Humanoid")
	
		-- Update immediately on spawn
		updateUI(humanoid)
	
		-- Listen for health changes
		humanoid.HealthChanged:Connect(function()
			updateUI(humanoid)
		end)
	end
	
	-- Since ResetOnSpawn is OFF, we handle the character lifecycle
	if player.Character then
		setupCharacter(player.Character)
	end
	
	player.CharacterAdded:Connect(setupCharacter)
end;
