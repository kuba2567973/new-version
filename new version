	local espTeamCheck = true
	local highlights = {}
	
	-- 1. STEJNÁ POKROČILÁ DETEKCE TÝMU JAKO U AIMBOTU (Fix pro Rivals)
	local function isFriendly(otherPlayer)
		if not espTeamCheck then return false end
		local lp = Players.LocalPlayer
	
		if otherPlayer.Team == lp.Team then return true end
		if otherPlayer.TeamColor == lp.TeamColor then return true end
		if otherPlayer:GetAttribute("Team") == lp:GetAttribute("Team") and lp:GetAttribute("Team") ~= nil then return true end
	
		local char = otherPlayer.Character
		local myChar = lp.Character
		if char and myChar then
			local oTeam = char:FindFirstChild("Team", true) or char:FindFirstChild("Side", true)
			local mTeam = myChar:FindFirstChild("Team", true) or myChar:FindFirstChild("Side", true)
			if oTeam and mTeam and oTeam.Value == mTeam.Value then return true end
		end
		return false
	end
	
	-- 2. PŘEVOD TEXTU NA BARVU
	local function stringToColor(str, defaultColor)
		local r, g, b = str:match("(%d+),%s*(%d+),%s*(%d+)")
		if r and g and b then
			return Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b))
		end
		return defaultColor
	end
	
	-- 3. SPRÁVA ESP (HIGHLIGHT)
	local function updateESP()
		local fill = stringToColor(esColBox.Text, Color3.fromRGB(255, 0, 0))
		local out = stringToColor(esOutBox.Text, Color3.fromRGB(255, 255, 255))
	
		for _, player in pairs(Players:GetPlayers()) do
			if player == Players.LocalPlayer then continue end
	
			local char = player.Character
			if char then
				local highlight = char:FindFirstChild("ESP_Highlight")
	
				-- Rozhodnutí, zda má být ESP vidět
				local shouldShow = espEnabled
				if espEnabled and espTeamCheck and isFriendly(player) then
					shouldShow = false
				end
	
				if shouldShow then
					if not highlight then
						highlight = Instance.new("Highlight")
						highlight.Name = "ESP_Highlight"
						highlight.Parent = char
					end
					highlight.Adornee = char
					highlight.FillColor = fill
					highlight.OutlineColor = out
					highlight.FillTransparency = 0.5
					highlight.Enabled = true
				else
					if highlight then highlight:Destroy() end
				end
			end
		end
	end
	
	-- 4. EVENTY
	espButton.MouseButton1Click:Connect(function()
		espEnabled = not espEnabled
		espButton.Text = espEnabled and "ESP-ON" or "ESP-OFF"
		updateESP()
	end)
	
	teamCheckButton.MouseButton1Click:Connect(function()
		espTeamCheck = not espTeamCheck
		teamCheckButton.Text = espTeamCheck and "TeamCheck_ESP-ON" or "TeamCheck_ESP-OFF"
		updateESP()
	end)
	
	-- Automatická aktualizace pro nové hráče a po respawnu
	Players.PlayerAdded:Connect(function(player)
		player.CharacterAdded:Connect(function()
			task.wait(0.5) -- Krátké čekání na načtení postavy
			updateESP()
		end)
	end)
	
	-- Sledování změn v TextBoxech
	esOutBox.FocusLost:Connect(updateESP)
	esColBox.FocusLost:Connect(updateESP)
	
	-- Pravidelná kontrola (pro jistotu, kdyby se změnil tým během hry)
	task.spawn(function()
		while task.wait(1) do
			updateESP()
		end
	end)
end;
