			if root then
				-- Načte rychlost z TextBoxu (pokud je prázdný nebo jsou tam písmena, použije 0)
				local speed = tonumber(textBox.Text) or 0
				root.CFrame = root.CFrame * CFrame.Angles(0, math.rad(speed), 0)
			end
			task.wait(0.01)
		end
	end)
end;
