local function C_16()
local script = G2L["16"];
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local UserInputService = game:GetService("UserInputService")
	
	local LocalPlayer = Players.LocalPlayer
	local Camera = workspace.CurrentCamera
	local Gui = script.Parent -- Předpokládá se, že skript je v ScreenGui
	
	-- FLEXIBILNÍ VYHLEDÁVÁNÍ (Najde tlačítka kdekoli v Gui podle jména)
	local function find(name)
		return Gui:FindFirstChild(name, true)
	end
	
	local mainButton = find("ambo")
	local teamButton = find("tmchk")
	local espButton = find("es")
	local espTeamButton = find("tmchkwh")
	local esOutBox = find("EsOut")
	local esColBox = find("EsCol")
	
	-- KONTROLA, ZDA SE VŠE NAŠLO
	if not (mainButton and teamButton and espButton and espTeamButton and esOutBox and esColBox) then
		warn("!!! AIMBOT ERROR: Některá tlačítka nebyla nalezena. Zkontrolujte jména v Exploreru!")
		return
	end
	
	local aimEnabled, aimTeamCheck = false, true
	local espEnabled, espTeamCheck = false, true
	local isRightClick = false
	
	-- 1. TEAM CHECK LOGIKA (RIVALS FIX)
	local function isEnemy(player)
		if not player or player == LocalPlayer then return false end
	
		-- Pokud je TeamCheck vypnutý (v módu FFA), považujeme za nepřítele kohokoliv jiného
		local checkActive = (aimEnabled and aimTeamCheck) or (espEnabled and espTeamCheck)
		if not checkActive then return true end
	
		-- Klasické týmy a TeamColor
		if player.Team ~= LocalPlayer.Team then return true end
		if player.TeamColor ~= LocalPlayer.TeamColor then return true end
	
		-- Atributy (Rivals)
		if player:GetAttribute("Team") ~= LocalPlayer:GetAttribute("Team") then return true end
	
		return false
	end
	
	-- 2. POMOCNÉ FUNKCE
	local function getRGB(txt, default)
		local r, g, b = txt:match("(%d+),%s*(%d+),%s*(%d+)")
		return r and Color3.fromRGB(tonumber(r), tonumber(g), tonumber(b)) or default
	end
	
	local function isVisible(part)
		local rayParams = RaycastParams.new()
		rayParams.FilterDescendantsInstances = {LocalPlayer.Character, Camera}
		rayParams.FilterType = Enum.RaycastFilterType.Exclude
		local res = workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, rayParams)
		return res and res.Instance:IsDescendantOf(part.Parent) or false
	end
	
	-- 3. LOGIKA TLAČÍTEK
	mainButton.MouseButton1Click:Connect(function()
		aimEnabled = not aimEnabled
		mainButton.Text = aimEnabled and "AimBot-ON" or "AimBot-OFF"
	end)
	
	teamButton.MouseButton1Click:Connect(function()
		aimTeamCheck = not aimTeamCheck
		teamButton.Text = aimTeamCheck and "TeamCheck-ON" or "TeamCheck-OFF (FFA)"
	end)
	
	espButton.MouseButton1Click:Connect(function()
		espEnabled = not espEnabled
		espButton.Text = espEnabled and "ESP-ON" or "ESP-OFF"
	end)
	
	espTeamButton.MouseButton1Click:Connect(function()
		espTeamCheck = not espTeamCheck
		espTeamButton.Text = espTeamCheck and "TeamCheck-ON" or "TeamCheck-OFF (FFA)"
	end)
	
	-- 4. VSTUPY
	UserInputService.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton2 then isRightClick = true end
	end)
	UserInputService.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton2 then 
			isRightClick = false 
			if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
				LocalPlayer.Character.Humanoid.AutoRotate = true
			end
		end
	end)
	
	-- 5. HLAVNÍ SMYČKA (60 FPS+)
	RunService.RenderStepped:Connect(function()
		local closest, dist = nil, math.huge
		local fillC = getRGB(esColBox.Text, Color3.fromRGB(255, 0, 0))
		local outC = getRGB(esOutBox.Text, Color3.fromRGB(255, 255, 255))
	
		for _, p in pairs(Players:GetPlayers()) do
			if p == LocalPlayer or not p.Character then continue end
			local char = p.Character
			local head = char:FindFirstChild("Head")
			local hum = char:FindFirstChild("Humanoid")
			if not head or not hum or hum.Health <= 0 then 
				if char:FindFirstChild("ESP_H") then char.ESP_H.Enabled = false end
				continue 
			end
	
			local enemy = isEnemy(p)
	
			-- ESP SYSTÉM
			local high = char:FindFirstChild("ESP_H")
			if espEnabled and (not espTeamCheck or enemy) then
				if not high then
					high = Instance.new("Highlight", char)
					high.Name = "ESP_H"
				end
				high.FillColor, high.OutlineColor, high.Enabled = fillC, outC, true
			elseif high then
				high.Enabled = false
			end
	
			-- AIMBOT SYSTÉM
			if aimEnabled and enemy and isRightClick and isVisible(head) then
				local d = (head.Position - Camera.CFrame.Position).Magnitude
				if d < dist then dist, closest = d, head end
			end
		end
	
		-- ZAMĚŘENÍ
		if closest then
			if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
				LocalPlayer.Character.Humanoid.AutoRotate = false
			end
			Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, closest.Position)
		end
	end)
	
	local Players = game:GetService("Players")
	local RunService = game:GetService("RunService")
	local LocalPlayer = Players.LocalPlayer
	
	-- CESTY K OBJEKTŮM
	local txbas = script.Parent:WaitForChild("txbas")
	local speedBox = txbas:WaitForChild("Speeed")
	
	-- LOKÁLNÍ PROMĚNNÉ PRO 4 TLAČÍTKA (Přejmenuj si je podle Exploreru)
	local b1 = txbas:WaitForChild("unfast")
	local b2 = txbas:WaitForChild("fast")
	local b3 = txbas:WaitForChild("midfast")
	local b4 = txbas:WaitForChild("megafast")
	
	local targetSpeed = 16 
	
	-- 1. FUNKCE PRO NASTAVENÍ RYCHLOSTI
	local function setSpeed(newSpeed)
		local val = tonumber(newSpeed)
		if val then
			targetSpeed = val
			speedBox.Text = tostring(val)
		end
	end
	
	-- 2. PŘIPOJENÍ TLAČÍTEK (Každé nastaví hodnotu podle svého textu)
	b1.MouseButton1Click:Connect(function() setSpeed(16) end)
	b2.MouseButton1Click:Connect(function() setSpeed(b2.Text) end)
	b3.MouseButton1Click:Connect(function() setSpeed(b3.Text) end)
	b4.MouseButton1Click:Connect(function() setSpeed(b4.Text) end)
	
	-- 3. LOGIKA TEXTBOXU
	speedBox.Focused:Connect(function()
		speedBox.Text = ""
	end)
	
	speedBox.FocusLost:Connect(function()
		setSpeed(speedBox.Text)
		if speedBox.Text == "" then speedBox.Text = tostring(targetSpeed) end
	end)
	
	-- 4. VYNUCENÍ RYCHLOSTI (Anti-Cheat & Crash protection)
	RunService.RenderStepped:Connect(function()
		local char = LocalPlayer.Character
		if not char then return end
	
		local humanoid = char:FindFirstChildOfClass("Humanoid")
		if humanoid then
			if humanoid.WalkSpeed ~= targetSpeed then
				pcall(function()
					humanoid.WalkSpeed = targetSpeed
				end)
			end
		end
	end)
	
end;
